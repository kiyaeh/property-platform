NODE_ENV=production
PORT=4000
# Runtime URL (recommended pooled connection for app traffic)
# Example:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooled-host>:6543/postgres?sslmode=require&pgbouncer=true

# Migration URL (direct database connection for Prisma migrate deploy)
# Example:
# postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
