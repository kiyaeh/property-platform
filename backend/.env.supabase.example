NODE_ENV=production
PORT=4000

# Runtime URL (recommended pooled connection for app traffic)
# Example:
# postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true

# Migration URL (direct database connection for Prisma migrate deploy)
# Example:
# postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true
DIRECT_DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
# postgresql://postgres:Kiy@eh121220@db.gyxkevbdkeubipoukaup.supabase.co:5432/postgres
# postgresql://postgres.gyxkevbdkeubipoukaup:[YOUR-PASSWORD]@aws-1-eu-central-2.pooler.supabase.com:6543/postgres
# postgresql://postgres.gyxkevbdkeubipoukaup:[YOUR-PASSWORD]@aws-1-eu-central-2.pooler.supabase.com:5432/postgres